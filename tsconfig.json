{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["bun-types", "@types/react", "@types/react-dom"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
